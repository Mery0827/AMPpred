# Python缓存
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ESM-2 预训练权重（需自行下载，体积大）
Rostlab/
*.bin
*.safetensors

# 数据集与特征（体积大，不上传）
dataset/**/*.csv
dataset/**/*.npy
dataset/**/features/
!dataset/**/README.md

# 特征提取脚本运行后生成的大文件（不应在 code/ 里）
feature_extract/**/*.pkl
feature_extract/**/*.npy

# 训练临时输出（日志、中间epoch、非最佳模型）
results/
outputs/
*.log
checkpoints/          # 排除临时检查点文件夹（里面全是中间epoch）
*.ckpt
*.h5

# 允许上传：你自己训练好的最佳模型（放在 weights/ 目录下）
!weights/
!weights/**/*.pth
!weights/**/*.pt

# IDE
.idea/
.vscode/

# 系统文件
.DS_Store
Thumbs.db
